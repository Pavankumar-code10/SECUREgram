{
  "expo": {
    "name": "SecureGram",
    "slug": "secure-gram-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pavan25.securegrammobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "securegram",
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d4590d42-15e5-4bed-8e9a-4d97af9847f7"
      }
    }
  }
}
